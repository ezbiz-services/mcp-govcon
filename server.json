{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "com.ezbizservices/govcon",
  "title": "EzBiz Government Contracting Intelligence",
  "description": "Federal contracting intelligence — contract search, agency spending, competitor wins.",
  "version": "1.0.0",
  "websiteUrl": "https://govcon.ezbizservices.com",
  "icons": [
    {
      "src": "https://raw.githubusercontent.com/sjcripps/mcp-govcon/main/static/icon.svg",
      "mimeType": "image/svg+xml",
      "sizes": ["200x200"]
    }
  ],
  "repository": {
    "url": "https://github.com/sjcripps/mcp-govcon",
    "source": "github"
  },
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://govcon.ezbizservices.com/mcp",
      "headers": [
        {
          "name": "x-api-key",
          "description": "Your EzBiz API key. Get a free key at https://govcon.ezbizservices.com/signup",
          "isRequired": true,
          "isSecret": true
        }
      ]
    }
  ]
}
